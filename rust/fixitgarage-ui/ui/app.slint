    in-out property <string> tr-home-reminders: "Reminders";
    in-out property <string> tr-home-scan-receipt: "Scan / log receipt";
    in-out property <string> tr-notes-body: "Body";
    in-out property <string> tr-notes-new: "New note";
    in-out property <string> tr-notes-save: "Save note";
    in-out property <string> tr-photos-caption-ph: "Caption (e.g. Front right leak)";
    in-out property <string> tr-photos-new: "New issue";
    in-out property <string> tr-photos-save: "Save issue log";
    in-out property <string> tr-photos-take: "Take photo";
    in-out property <string> tr-receipt-apply-shared: "Apply shared OCR";
    in-out property <string> tr-receipt-auto-fill: "Auto-fill from text above";
    in-out property <string> tr-receipt-capture: "Capture for OCR";
    in-out property <string> tr-receipt-fields: "Receipt fields";
    in-out property <string> tr-receipt-hint: "On-device OCR (no Google): Capture photo → On-device OCR. Fallback: Send to OCR app / Share text back / Paste & fill.";
    in-out property <string> tr-receipt-ocr-helper: "OCR helper";
    in-out property <string> tr-receipt-ondevice-ocr: "On-device OCR";
    in-out property <string> tr-receipt-parse: "Parse text above";
    in-out property <string> tr-receipt-paste-ph: "Paste receipt text (OCR share / email / clipboard)";
    in-out property <string> tr-receipt-save: "Save receipt to history";
    in-out property <string> tr-receipt-send-ocr: "Send photo to OCR app";
    in-out property <string> tr-receipt-title-ph: "Title (e.g. Oil change shop)";
    in-out property <string> tr-rem-add: "Add reminder";
    in-out property <string> tr-rem-due-date: "Due date YYYY-MM-DD";
    in-out property <string> tr-rem-reboot-hint: "Date-based alarms are saved on this device. After a phone restart, FixItGarage re-registers them automatically.";
    in-out property <string> tr-rem-save: "Save reminder";
    in-out property <string> tr-rem-title: "Reminders";
    in-out property <string> tr-settings-about-body: "FixItGarage — security hardening: backups, HTTPS WebDAV, no Auto Backup.";
    in-out property <string> tr-settings-accessibility: "Accessibility · reading";
    in-out property <string> tr-settings-accessibility-body: "";
    in-out property <string> tr-settings-backup-path-ph: "Backup file path to restore";
    in-out property <string> tr-settings-cloud-body: "";
    in-out property <string> tr-settings-create-backup: "Create JSON backup";
    in-out property <string> tr-settings-default-font: "Default font";
    in-out property <string> tr-settings-dropbox: "Dropbox";
    in-out property <string> tr-settings-export-csv: "Export CSV";
    in-out property <string> tr-settings-google-drive: "Google Drive";
    in-out property <string> tr-settings-gpl: "GPL-3.0 · GrapheneOS friendly";
    in-out property <string> tr-settings-onedrive: "OneDrive";
    in-out property <string> tr-settings-password-ph: "App password (blank = keep existing)";
    in-out property <string> tr-settings-proton: "★ Proton Drive (recommended)";
    in-out property <string> tr-settings-restore: "Restore from path";
    in-out property <string> tr-settings-save-webdav: "Save WebDAV settings";
    in-out property <string> tr-settings-share-backup: "Share backup (any app)";
    in-out property <string> tr-settings-share-csv: "Share CSV";
    in-out property <string> tr-settings-upload-webdav: "Upload backup via WebDAV";
    in-out property <string> tr-settings-username: "Username";
    in-out property <string> tr-settings-webdav-hint: "HTTPS only. Example: https://cloud.example/remote.php/dav/files/USER/FixItGarage/ — password stays on this device, never in shared backups, never re-shown after save. Leave password blank to keep the existing one.";
    in-out property <string> tr-settings-webdav-url-ph: "WebDAV folder URL (https://…)";
    in-out property <string> tr-tires-after-preview: "After rotation (preview)";
    in-out property <string> tr-tires-apply-rotation: "Apply rotation";
    in-out property <string> tr-tires-camera-coin: "Camera (coin in groove)";
    in-out property <string> tr-tires-current-before: "Current positions (before)";
    in-out property <string> tr-tires-distance: "Distance per tire";
    in-out property <string> tr-tires-front-view: "FRONT · top-down view";
    in-out property <string> tr-tires-hidden: "Hidden in shop-only mode. Switch feature focus in Settings.";
    in-out property <string> tr-tires-include-spare: "Include spare";
    in-out property <string> tr-tires-measure-cv: "Measure tread (CV)";
    in-out property <string> tr-tires-paste-fill: "Paste & fill";
    in-out property <string> tr-tires-paste-receipt: "Paste tire receipt text";
    in-out property <string> tr-tires-positions-hint: "Tire positions are saved per vehicle — switch cars to see each layout.";
    in-out property <string> tr-tires-purchase: "Tire purchase";
    in-out property <string> tr-tires-purchase-body: "";
    in-out property <string> tr-tires-purchase-history: "Purchase history";
    in-out property <string> tr-tires-rotation-history: "Rotation history";
    in-out property <string> tr-tires-rotation-pattern: "Rotation pattern";
    in-out property <string> tr-tires-save-distance: "Save tire distance";
    in-out property <string> tr-tires-save-purchase: "Save tire purchase";
    in-out property <string> tr-tires-save-tread: "Save tread depths";
    in-out property <string> tr-tires-size-ph: "Size (e.g. 225/65R17)";
    in-out property <string> tr-tires-spare-body: "";
    in-out property <string> tr-tires-spare-title: "";
    in-out property <string> tr-tires-tread-depth: "Tread depth";
    in-out property <string> tr-vehicles-add-body: "";
    in-out property <string> tr-vehicles-add-title: "";
    in-out property <string> tr-vehicles-check-recalls: "Check recalls for VIN";
    in-out property <string> tr-vehicles-delete: "Delete selected vehicle";
    in-out property <string> tr-vehicles-edit-title: "";
    in-out property <string> tr-vehicles-hint: "Tap a vehicle to select it for services, costs, and trackers.";
    in-out property <string> tr-vehicles-make-ph: "Make";
    in-out property <string> tr-vehicles-model-ph: "Model";
    in-out property <string> tr-vehicles-name-ph: "Name / nickname";
    in-out property <string> tr-vehicles-open-nhtsa: "Open NHTSA VIN page";
    in-out property <string> tr-vehicles-recalls-body: "";
    in-out property <string> tr-vehicles-recalls-title: "";
    in-out property <string> tr-vehicles-save: "Save vehicle";
    in-out property <string> tr-vehicles-save-changes: "Save changes";
    in-out property <string> tr-vehicles-selected: "SELECTED";
    in-out property <string> tr-vehicles-update-odo: "Update odometer only";
    in-out property <string> tr-vehicles-vin-opt-ph: "VIN (17 characters, optional)";
    in-out property <string> tr-vehicles-vin-ph: "VIN (17 characters)";
    in-out property <string> tr-vehicles-year-ph: "Year";
    in-out property <string> tr-wizard-both: "Both DIY and shop";
    in-out property <string> tr-wizard-diy: "Mostly DIY";
    in-out property <string> tr-wizard-diy-body: "Parts, oil, tires, DIY logging first.";
    in-out property <string> tr-wizard-intro: "How do you mostly maintain your vehicles? We'll show the tools that fit you.";
    in-out property <string> tr-wizard-shop: "Mostly shop";
    in-out property <string> tr-wizard-shop-body: "Shop history, costs, service focus.";
    in-out property <string> tr-wizard-units-note: "Units (can change later in Settings)";
    in-out property <string> tr-wizard-welcome: "Welcome to FixItGarage";
    // Oil level choice labels (swap with unit system)
    in-out property <string> oil-opt-0: "Full";
    in-out property <string> oil-opt-1: "½ quart low";
    in-out property <string> oil-opt-2: "1 quart low";
    in-out property <string> oil-opt-3: "2 quarts low";
    in-out property <string> oil-opt-4: "3 quarts low";
    in-out property <string> oil-opt-5: "Overfilled";

    callback finish-wizard(string);
    callback navigate(int);
    callback select-vehicle(int);
    callback add-vehicle();
    callback add-service();
    /// Pre-fill service form: "oil" | "fuel" | "rotation" | "shop"
    callback fill-service-template(string);
    callback apply-rotation();
    callback set-pattern(string);
    callback set-include-spare(bool);
    callback set-spare-label();
    callback set-source(string);
    callback set-user-mode(string);
    callback set-dark-mode(string);
    callback set-units(string);
    callback set-language(string);
    callback set-dyslexia-font(bool);
    callback save-part();
    callback save-component();
    callback add-note();
    callback add-reminder();
    callback complete-reminder(int);
    callback set-oil-level-choice(string);
    callback add-photo();
    callback capture-photo();
    callback save-receipt();
    callback save-tire-purchase();
    callback delete-tire-purchase(int);
    callback update-selected-mileage();
    callback delete-selected-vehicle();
    callback delete-service(int);
    callback delete-note(int);
    callback save-tread();
    callback capture-tread-photo();
    callback parse-tire-receipt();
    callback save-tire-miles();
    callback export-csv();
    callback share-csv();
    callback backup-json();
    callback restore-json();
    callback share-backup();
    /// target: "proton" | "gdrive" | "dropbox" | "any"
    callback share-backup-to(string);
    callback capture-receipt-photo();
    callback parse-receipt-text();
    callback paste-receipt-clipboard();
    callback paste-tire-clipboard();
    callback open-ocr-helper();
    /// Capture photo into MediaStore + remember for OCR share.
    callback capture-receipt-for-ocr();
    /// ACTION_SEND image to Text Fairy / Lens / chooser.
    callback send-receipt-to-ocr();
    /// Consume shared OCR text (Share → FixItGarage) and auto-fill.
    callback apply-pending-ocr();
    /// Pure-Rust on-device OCR (ocrs) — no GMS.
    callback ocr-receipt-on-device();
    /// Coin-gauge tread depth CV from photo.
    callback measure-tread-cv();
    callback save-cloud-settings();
    callback upload-cloud-backup();
    callback update-selected-vehicle();
    /// Decode VIN via NHTSA and list recalls for that vehicle.
    callback check-recalls();
    /// Open NHTSA.gov VIN recall page in browser.
    callback open-nhtsa-vin-page();
    callback set-service-search(string);
    callback open-feedback();
    callback open-donate();
    /// PDF + text packet for selling the selected vehicle.
    callback create-seller-packet();
    callback share-seller-summary();

    changed dark-mode => { Theme.dark = (root.dark-mode == "DARK"); }
    changed dyslexia-font => { Theme.dyslexia-font = root.dyslexia-font; }

    // ===== Wizard =====
    if !wizard-done: Rectangle {
        width: 100%; height: 100%; background: Theme.bg;
        VerticalBox {
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 24px + root.safe-area-top;
            padding-bottom: 24px + root.safe-area-bottom;
            spacing: 14px;
            alignment: start;
            Text { text: root.tr-wizard-welcome; font-size: 26px; font-weight: 800; color: Theme.title; wrap: word-wrap; }
            Text {
                text: root.tr-wizard-intro;
                font-size: 15px; color: Theme.text-muted; wrap: word-wrap;
            }
            Button { text: root.tr-wizard-diy; primary: true; clicked => { root.finish-wizard("DIY"); } }
            Text { text: root.tr-wizard-diy-body; font-size: 12px; color: Theme.text-muted; wrap: word-wrap; }
            Button { text: root.tr-wizard-shop; primary: true; clicked => { root.finish-wizard("SHOP"); } }
            Text { text: root.tr-wizard-shop-body; font-size: 12px; color: Theme.text-muted; wrap: word-wrap; }
            ChoiceBtn { label: root.tr-wizard-both; active: false; clicked => { root.finish-wizard("BOTH"); } }
            HorizontalBox {
                spacing: 8px;
                ChoiceBtn { label: root.tr-common-dark; active: root.dark-mode == "DARK"; clicked => { root.set-dark-mode("DARK"); } }
                ChoiceBtn { label: root.tr-common-light; active: root.dark-mode == "LIGHT"; clicked => { root.set-dark-mode("LIGHT"); } }
            }
            Text { text: root.tr-wizard-units-note; font-size: 13px; color: Theme.text-muted; }
            HorizontalBox {
                spacing: 8px;
                ChoiceBtn { label: root.tr-common-imperial; active: root.units == "IMPERIAL"; clicked => { root.set-units("IMPERIAL"); } }
                ChoiceBtn { label: root.tr-common-metric; active: root.units == "METRIC"; clicked => { root.set-units("METRIC"); } }
            }
        }
    }

    if wizard-done: VerticalLayout {
        spacing: 0;
        // Clear status bar / camera cutout
        Rectangle { height: root.safe-area-top; background: Theme.bg; }
        Rectangle {
            vertical-stretch: 1; background: Theme.bg;

            // HOME
            if page == 0: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 12px;
                    HorizontalBox {
                        spacing: 8px;
                        Text {
                            text: root.tr-app-title; font-size: 28px; font-weight: 800; color: Theme.title;
                            horizontal-stretch: 1; vertical-alignment: center;
                        }
                        Button { text: "⚙"; clicked => { root.navigate(15); } }
                    }
                    Text { text: mode-label; font-size: 14px; color: Theme.text-muted; }
                    VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    Card {
                        title: root.tr-home-glance;
                        body: "";
                        Text { text: dash-mpg; font-size: 16px; font-weight: 700; color: Theme.text; }
                        Text { text: dash-month; font-size: 14px; color: Theme.text; }
                        Text { text: dash-year; font-size: 14px; color: Theme.text; }
                        Text { text: dash-dues; font-size: 13px; color: Theme.text-muted; wrap: word-wrap; }
                        Button { text: root.tr-home-fuel; clicked => { root.navigate(14); } }
                        Button { text: root.nav-costs; clicked => { root.navigate(4); } }
                    }
                    if has-due-reminders: Card {
                        title: root.tr-home-due;
                        body: due-reminders-banner;
                        Button { text: root.tr-home-open-reminders; primary: true; clicked => { root.navigate(11); } }
                    }
                    Card {
                        title: root.tr-home-upcoming;
                        body: "";
                        if upcoming-reminders.length == 0: Text {
                            text: root.tr-home-no-upcoming;
                            font-size: 13px; color: Theme.text-muted; wrap: word-wrap;
                        }
                        for u in upcoming-reminders: Text {
                            text: u.title + " — " + u.detail;
                            font-size: 13px; color: Theme.text; wrap: word-wrap;
                        }
                        Button { text: root.tr-home-manage-reminders; clicked => { root.navigate(11); } }
                    }
                    if has-low-tread: Card {
                        title: root.tr-home-tread;
                        body: tread-warning;
                        Button { text: root.tr-home-open-tires; primary: true; clicked => { root.navigate(3); } }
                    }
                    if has-old-battery: Card {
                        title: root.tr-page-battery;
                        body: battery-warning;
                        Button { text: root.tr-home-open-battery; primary: true; clicked => { root.navigate(7); } }
                    }
                    if has-brakes-due: Card {
                        title: root.tr-page-brakes;
                        body: brake-warning;
                        Button { text: root.tr-home-open-brakes; primary: true; clicked => { root.navigate(9); } }
                    }
                    if has-old-wipers: Card {
                        title: root.tr-page-wipers;
                        body: wiper-warning;
                        Button { text: root.tr-home-open-wipers; primary: true; clicked => { root.navigate(8); } }
                    }
                    Card {
                        title: root.tr-home-last-service; body: "";
                        Text { text: last-service-title; font-size: 15px; font-weight: 600; color: Theme.text; wrap: word-wrap; }
                        Text { text: last-service-detail; font-size: 13px; color: Theme.text-soft; wrap: word-wrap; }
                    }
                    Card {
                        title: root.tr-home-vehicles; body: vehicle-count-label;
                        Button { text: root.tr-home-manage-vehicles; clicked => { root.navigate(1); } }
                    }
                    Card {
                        title: root.tr-home-quick;
                        body: last-oil-level-summary;
                        Button { text: root.tr-home-oil-level; primary: true; clicked => { root.navigate(11); } }
                        Button { text: root.tr-home-scan-receipt; clicked => { root.navigate(13); } }
                        Button { text: root.tr-more-photos; clicked => { root.navigate(12); } }
                        Button { text: root.tr-home-log-service; clicked => { root.navigate(2); } }
                        Button { text: root.tr-home-fuel; clicked => { root.navigate(14); } }
                        if show-tires: Button { text: root.tr-home-tire-rotation; clicked => { root.navigate(3); } }
                        if show-parts: Button { text: root.tr-more-parts; clicked => { root.navigate(6); } }
                        Button { text: root.tr-home-reminders; clicked => { root.navigate(11); } }
                        Button { text: root.tr-more-notes; clicked => { root.navigate(10); } }
                    }
                    if status-message != "": Text { text: status-message; color: Theme.ok; font-size: 12px; wrap: word-wrap; }
                }
            }

            // VEHICLES
            if page == 1: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 10px;
                    PageTitle { label: root.tr-page-vehicles; }
                    Text { text: root.tr-vehicles-hint; font-size: 13px; color: Theme.text-muted; wrap: word-wrap; }
                    Card {
                        title: root.tr-vehicles-add-title; body: root.tr-vehicles-add-body;
                        LineEdit { placeholder-text: root.tr-vehicles-name-ph; text <=> root.form-name; }
                        LineEdit { placeholder-text: root.tr-vehicles-vin-opt-ph; text <=> root.form-vin; }
                        LineEdit { placeholder-text: root.tr-vehicles-make-ph; text <=> root.form-make; }
                        LineEdit { placeholder-text: root.tr-vehicles-model-ph; text <=> root.form-model; }
                        HorizontalBox {
                            LineEdit { placeholder-text: root.tr-vehicles-year-ph; text <=> root.form-year; horizontal-stretch: 1; }
                            LineEdit { placeholder-text: root.label-distance; text <=> root.form-mileage; horizontal-stretch: 1; }
                        }
                        Button { text: root.tr-vehicles-save; primary: true; clicked => { root.add-vehicle(); } }
                    }
                    Card {
                        title: root.tr-vehicles-edit-title;
                        body: selected-vehicle-label;
                        LineEdit { placeholder-text: root.tr-vehicles-name-ph; text <=> root.form-name; }
                        LineEdit { placeholder-text: root.tr-vehicles-vin-ph; text <=> root.form-vin; }
                        LineEdit { placeholder-text: root.tr-vehicles-make-ph; text <=> root.form-make; }
                        LineEdit { placeholder-text: root.tr-vehicles-model-ph; text <=> root.form-model; }
                        HorizontalBox {
                            LineEdit { placeholder-text: root.tr-vehicles-year-ph; text <=> root.form-year; horizontal-stretch: 1; }
                            LineEdit { placeholder-text: root.label-distance; text <=> root.form-mileage; horizontal-stretch: 1; }
                        }
                        Button { text: root.tr-vehicles-save-changes; primary: true; clicked => { root.update-selected-vehicle(); } }
                        Button { text: root.tr-vehicles-update-odo; clicked => { root.update-selected-mileage(); } }
                        Button { text: root.tr-vehicles-delete; clicked => { root.delete-selected-vehicle(); } }
                    }
                    Card {
                        title: root.tr-vehicles-recalls-title;
                        body: root.tr-vehicles-recalls-body;
                        Button { text: root.tr-vehicles-check-recalls; primary: true; clicked => { root.check-recalls(); } }
                        Button { text: root.tr-vehicles-open-nhtsa; clicked => { root.open-nhtsa-vin-page(); } }
                        if recall-status != "": Text {
                            text: recall-status;
                            font-size: 13px; color: Theme.ok; wrap: word-wrap;
                        }
                        for r in recalls: Card {
                            title: r.campaign + " · " + r.component;
                            body: r.summary;
                        }
                    }
                    for v in vehicles: TouchArea {
                        clicked => { root.select-vehicle(v.id); }
                        Card {
                            title: v.name;
                            body: v.subtitle + " · " + v.mileage + (v.id == root.selected-vehicle-id ? " · " + root.tr-vehicles-selected : "");
                        }
                    }
                }
            }

            // SERVICE
            if page == 2: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 10px;
                    PageTitle { label: root.tr-page-service; }
                    VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    Text { text: mpg-label; font-size: 13px; color: Theme.text-muted; wrap: word-wrap; }
                    LineEdit {
                        placeholder-text: root.tr-svc-search-ph;
                        text <=> root.service-search;
                        edited => { root.set-service-search(root.service-search); }
                    }
                    Card {
                        title: root.tr-svc-quick-templates; body: root.tr-svc-quick-templates-body;
                        HorizontalBox {
                            spacing: 6px;
                            Button { text: root.tr-svc-oil-change; clicked => { root.fill-service-template("oil"); } }
                            Button { text: root.tr-svc-fuel-fill; clicked => { root.fill-service-template("fuel"); } }
                        }
                        HorizontalBox {
                            spacing: 6px;
                            Button { text: root.tr-home-tire-rotation; clicked => { root.fill-service-template("rotation"); } }
                            Button { text: root.tr-svc-shop-visit; clicked => { root.fill-service-template("shop"); } }
                        }
                    }
                    Card {
                        title: root.tr-svc-log-title; body: root.tr-svc-log-body;
                        LineEdit { placeholder-text: root.tr-svc-title-ph; text <=> root.svc-title; }
                        LineEdit { placeholder-text: root.label-distance; text <=> root.svc-mileage; }
                        HorizontalBox {
                            spacing: 8px;
                            ChoiceBtn { label: root.tr-svc-diy; active: root.svc-source == "DIY"; clicked => { root.set-source("DIY"); } }
                            ChoiceBtn { label: root.tr-svc-shop; active: root.svc-source == "SHOP"; clicked => { root.set-source("SHOP"); } }
                        }
                        LineEdit { placeholder-text: root.tr-svc-parts-cost; text <=> root.svc-cost; }
                        LineEdit { placeholder-text: root.tr-svc-labor-cost; text <=> root.svc-labor; }
                        LineEdit { placeholder-text: root.label-fuel + " " + root.tr-svc-fuel-optional; text <=> root.svc-gallons; }
                        LineEdit { placeholder-text: root.tr-svc-fuel-cost-ph; text <=> root.svc-fuel; }
                        if root.svc-source == "SHOP": LineEdit { placeholder-text: root.tr-svc-shop-name-ph; text <=> root.svc-shop; }
                        LineEdit { placeholder-text: root.tr-svc-notes-ph; text <=> root.svc-notes; }
                        Button { text: root.tr-svc-save; primary: true; clicked => { root.add-service(); } }
                    }
                    for s in services: Card {
                        title: s.title; body: s.subtitle + (s.cost != "" ? " · " + s.cost : "");
                        Button { text: root.tr-common-delete; clicked => { root.delete-service(s.id); } }
                    }
                }
            }

            // TIRES
            if page == 3: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 12px;
                    PageTitle { label: root.tr-page-tires; }
                    if !show-tires: Text { text: root.tr-tires-hidden; color: Theme.text-muted; wrap: word-wrap; }
                    if show-tires: VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    if show-tires: Text {
                        text: root.tr-tires-positions-hint;
                        font-size: 12px; color: Theme.text-muted; wrap: word-wrap;
                    }
                    if show-tires: Card {
                        title: root.tr-tires-current-before; body: root.tr-tires-front-view;
                        Rectangle {
                            height: root.include-spare ? 280px : 220px; background: transparent;
                            Rectangle {
                                x: (parent.width - 140px) / 2; y: 20px; width: 140px; height: 180px;
                                border-radius: 28px; background: Theme.car-body; border-width: 2px; border-color: Theme.car-outline;
                            }
                            TireCorner { x: 12px; y: 12px; label: root.tire-fl; }
                            TireCorner { x: parent.width - 68px; y: 12px; label: root.tire-fr; }
                            TireCorner { x: 12px; y: parent.height - (root.include-spare ? 120px : 60px); label: root.tire-rl; }
                            TireCorner { x: parent.width - 68px; y: parent.height - (root.include-spare ? 120px : 60px); label: root.tire-rr; }
                            if root.include-spare: TireCorner {
                                x: (parent.width - 56px) / 2;
                                y: parent.height - 56px;
                                label: "SP " + root.tire-spare;
                            }
                        }
                    }
                    if show-tires: Card {
                        title: root.tr-tires-after-preview; body: tire-preview;
                        Rectangle {
                            height: root.include-spare ? 280px : 220px; background: transparent;
                            Rectangle {
                                x: (parent.width - 140px) / 2; y: 20px; width: 140px; height: 180px;
                                border-radius: 28px; background: Theme.car-body; border-width: 2px; border-color: Theme.ok;
                            }
                            TireCorner { x: 12px; y: 12px; label: root.tire-after-fl; }
                            TireCorner { x: parent.width - 68px; y: 12px; label: root.tire-after-fr; }
                            TireCorner { x: 12px; y: parent.height - (root.include-spare ? 120px : 60px); label: root.tire-after-rl; }
                            TireCorner { x: parent.width - 68px; y: parent.height - (root.include-spare ? 120px : 60px); label: root.tire-after-rr; }
                            if root.include-spare: TireCorner {
                                x: (parent.width - 56px) / 2;
                                y: parent.height - 56px;
                                label: "SP " + root.tire-after-spare;
                            }
                        }
                        Text {
                            text: "Tread depths and mileage per tire move with each corner when you apply.";
                            font-size: 12px; color: Theme.text-muted; wrap: word-wrap;
                        }
                    }
                    if show-tires: Card {
                        title: root.tr-tires-spare-title; body: root.tr-tires-spare-body;
                        HorizontalBox {
                            spacing: 6px;
                            ChoiceBtn {
                                label: "4 tires only";
                                active: !root.include-spare;
                                clicked => { root.set-include-spare(false); }
                            }
                            ChoiceBtn {
                                label: root.tr-tires-include-spare;
                                active: root.include-spare;
                                clicked => { root.set-include-spare(true); }
                            }
                        }
                        if root.include-spare: LineEdit {
                            placeholder-text: "Spare tire ID (e.g. E)";
                            text <=> root.tire-spare;
                            edited => { root.set-spare-label(); }
                        }
                        if root.include-spare: Text {
                            text: "5-tire patterns cycle the spare into the corners so rubber wears evenly.";
                            font-size: 12px; color: Theme.text-muted; wrap: word-wrap;
                        }
                    }
                    if show-tires: Card {
                        title: root.tr-tires-rotation-pattern; body: root.include-spare ? "5-tire patterns (spare included)" : "4-tire patterns (spare stays put)";
                        HorizontalBox {
                            spacing: 6px;
                            ChoiceBtn { label: "Fwd cross"; active: root.tire-pattern == "forward_cross"; clicked => { root.set-pattern("forward_cross"); } }
                            ChoiceBtn { label: "X"; active: root.tire-pattern == "x_pattern"; clicked => { root.set-pattern("x_pattern"); } }
                        }
                        HorizontalBox {
                            spacing: 6px;
                            ChoiceBtn { label: "Rear cross"; active: root.tire-pattern == "rearward_cross"; clicked => { root.set-pattern("rearward_cross"); } }
                            ChoiceBtn { label: "Side"; active: root.tire-pattern == "side_to_side"; clicked => { root.set-pattern("side_to_side"); } }
                        }
                        Button { text: root.tr-tires-apply-rotation; primary: true; clicked => { root.apply-rotation(); } }
                    }
                    if show-tires: Card {
                        title: root.tr-tires-tread-depth + " (" + root.label-tread + ")";
                        body: tread-summary;
                        Text {
                            text: tread-warning;
                            font-size: 13px; font-weight: 600; color: Theme.ok; wrap: word-wrap;
                        }
                        Text {
                            text: tread-coin-guide;
                            font-size: 12px; color: Theme.text-muted; wrap: word-wrap;
                        }
                        HorizontalBox {
                            spacing: 6px;
                            Button { text: root.tr-tires-camera-coin; clicked => { root.capture-tread-photo(); } }
                            Button { text: root.tr-tires-measure-cv; primary: true; clicked => { root.measure-tread-cv(); } }
                        }
                        Text {
                            text: tread-photo-path == "" ? "Photo a US penny seated in the tread, then Measure." : ("Photo: " + tread-photo-path);
                            font-size: 11px; color: Theme.text-soft; wrap: word-wrap;
                        }
                        HorizontalBox {
                            LineEdit { placeholder-text: "FL " + root.label-tread; text <=> root.tread-fl; horizontal-stretch: 1; }
                            LineEdit { placeholder-text: "FR " + root.label-tread; text <=> root.tread-fr; horizontal-stretch: 1; }
                        }
                        HorizontalBox {
                            LineEdit { placeholder-text: "RL " + root.label-tread; text <=> root.tread-rl; horizontal-stretch: 1; }
                            LineEdit { placeholder-text: "RR " + root.label-tread; text <=> root.tread-rr; horizontal-stretch: 1; }
                        }
                        if root.include-spare: LineEdit {
                            placeholder-text: "SP " + root.label-tread;
                            text <=> root.tread-spare;
                        }
                        Button { text: root.tr-tires-save-tread; primary: true; clicked => { root.save-tread(); } }
                    }
                    if show-tires: Card {
                        title: root.tr-tires-distance;
                        body: tire-miles-summary;
                        Text {
                            text: "Odometer on this tire for each corner (" + root.unit-distance + ") — helps plan rotations.";
                            font-size: 12px; color: Theme.text-muted; wrap: word-wrap;
                        }
                        HorizontalBox {
                            LineEdit { placeholder-text: "FL " + root.unit-distance; text <=> root.mi-fl; horizontal-stretch: 1; }
                            LineEdit { placeholder-text: "FR " + root.unit-distance; text <=> root.mi-fr; horizontal-stretch: 1; }
                        }
                        HorizontalBox {
                            LineEdit { placeholder-text: "RL " + root.unit-distance; text <=> root.mi-rl; horizontal-stretch: 1; }
                            LineEdit { placeholder-text: "RR " + root.unit-distance; text <=> root.mi-rr; horizontal-stretch: 1; }
                        }
                        if root.include-spare: LineEdit {
                            placeholder-text: "SP " + root.unit-distance;
                            text <=> root.mi-spare;
                        }
                        Button { text: root.tr-tires-save-distance; primary: true; clicked => { root.save-tire-miles(); } }
                    }
                    if show-tires: Card {
                        title: root.tr-tires-purchase; body: root.tr-tires-purchase-body;
                        LineEdit { placeholder-text: root.tr-tires-paste-receipt; text <=> root.tire-rcp-paste; }
                        HorizontalBox {
                            spacing: 6px;
                            Button { text: root.tr-tires-paste-fill; primary: true; clicked => { root.paste-tire-clipboard(); } }
                            Button { text: root.tr-receipt-ocr-helper; clicked => { root.open-ocr-helper(); } }
                        }
                        Button { text: root.tr-receipt-parse; clicked => { root.parse-tire-receipt(); } }
                        LineEdit { placeholder-text: "Brand"; text <=> root.tire-brand; }
                        LineEdit { placeholder-text: root.tr-vehicles-model-ph; text <=> root.tire-model; }
                        LineEdit { placeholder-text: root.tr-tires-size-ph; text <=> root.tire-size; }
                        LineEdit { placeholder-text: "Cost"; text <=> root.tire-cost; }
                        LineEdit { placeholder-text: root.label-distance + " at purchase"; text <=> root.tire-buy-mileage; }
                        LineEdit { placeholder-text: "Notes"; text <=> root.tire-buy-notes; }
                        Button { text: root.tr-tires-save-purchase; primary: true; clicked => { root.save-tire-purchase(); } }
                    }
                    if show-tires: Card {
                        title: root.tr-tires-purchase-history; body: "";
                        for p in tire-purchases: Card {
                            title: p.title;
                            body: p.detail;
                            Button { text: "Delete"; clicked => { root.delete-tire-purchase(p.id); } }
                        }
                    }
                    if show-tires: Card {
                        title: root.tr-tires-rotation-history; body: "";
                        for r in tire-rotations: Text {
                            text: r.title + " — " + r.detail;
                            font-size: 13px; color: Theme.text; wrap: word-wrap;
                        }
                    }
                }
            }

            // COSTS
            if page == 4: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 12px;
                    PageTitle { label: root.tr-page-costs; }
                    VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    Text {
                        text: root.tr-costs-body;
                        font-size: 13px; color: Theme.text-muted; wrap: word-wrap;
                    }
                    for c in cost-lines: Card { title: c.label; body: c.value; }
                }
            }

            // MORE — tools & trackers hub (not settings)
            if page == 5: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 12px;
                    HorizontalBox {
                        spacing: 8px;
                        PageTitle { label: root.tr-more-title; horizontal-stretch: 1; }
                        Button { text: "⚙ " + root.nav-settings; clicked => { root.navigate(15); } }
                    }
                    Text {
                        text: root.tr-more-intro;
                        font-size: 13px; color: Theme.text-muted; wrap: word-wrap;
                    }
                    VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    Card {
                        title: root.tr-more-trackers; body: "";
                        if show-parts: Button { text: root.tr-more-parts; clicked => { root.navigate(6); } }
                        Button { text: root.tr-more-battery; clicked => { root.navigate(7); } }
                        Button { text: root.tr-more-wipers; clicked => { root.navigate(8); } }
                        Button { text: root.tr-more-brakes; clicked => { root.navigate(9); } }
                    }
                    Card {
                        title: root.tr-more-logs; body: "";
                        Button { text: root.tr-more-notes; clicked => { root.navigate(10); } }
                        Button { text: root.tr-more-reminders; clicked => { root.navigate(11); } }
                        Button { text: root.tr-more-photos; clicked => { root.navigate(12); } }
                        Button { text: root.tr-more-receipts; clicked => { root.navigate(13); } }
                        Button { text: root.tr-more-fuel; clicked => { root.navigate(14); } }
                    }
                    Card {
                        title: root.tr-more-quick; body: "";
                        Button { text: root.tr-home-log-service; clicked => { root.navigate(2); } }
                        if show-tires: Button { text: root.tr-more-tire-tracker; clicked => { root.navigate(3); } }
                        Button { text: root.nav-costs; clicked => { root.navigate(4); } }
                        Button { text: root.tr-more-open-settings; primary: true; clicked => { root.navigate(15); } }
                    }
                    Card {
                        title: root.tr-more-selling;
                        body: root.tr-more-selling-body;
                        Button { text: root.tr-more-seller-pdf; primary: true; clicked => { root.create-seller-packet(); } }
                        Button { text: root.tr-more-seller-text; clicked => { root.share-seller-summary(); } }
                    }
                }
            }

            // SETTINGS — preferences only (gear tab)
            if page == 15: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    // Extra bottom pad so the last language options / cards are scrollable
                    // above the app nav + system navigation bar.
                    padding-left: 16px;
                    padding-right: 16px;
                    padding-top: 16px;
                    padding-bottom: 48px + root.safe-area-bottom;
                    spacing: 12px;
                    PageTitle { label: root.tr-settings-title; }
                    Text {
                        text: root.tr-settings-intro;
                        font-size: 13px; color: Theme.text-muted; wrap: word-wrap;
                    }
                    Card {
                        title: root.tr-settings-appearance; body: root.tr-settings-appearance-body;
                        HorizontalBox {
                            spacing: 8px;
                            ChoiceBtn { label: root.tr-settings-dark; active: root.dark-mode == "DARK"; clicked => { root.set-dark-mode("DARK"); } }
                            ChoiceBtn { label: root.tr-settings-light; active: root.dark-mode == "LIGHT"; clicked => { root.set-dark-mode("LIGHT"); } }
                        }
                        Text {
                            text: root.dark-mode == "DARK" ? "Using dark mode (saved)" : "Using light mode (saved)";
                            font-size: 12px; color: Theme.text-muted; wrap: word-wrap;
                        }
                    }
                    Card {
                        title: root.tr-settings-accessibility;
                        body: root.tr-settings-accessibility-body;
                        HorizontalBox {
                            spacing: 6px;
                            ChoiceBtn {
                                label: root.tr-settings-default-font;
                                active: !root.dyslexia-font;
                                clicked => { root.set-dyslexia-font(false); }
                            }
                            ChoiceBtn {
                                label: "OpenDyslexic";
                                active: root.dyslexia-font;
                                clicked => { root.set-dyslexia-font(true); }
                            }
                        }
                        Text {
                            text: root.dyslexia-font
                                ? "OpenDyslexic is on. Sample: oil filter 1 qt · 30,000 mi"
                                : "Using the system default UI font.";
                            font-size: 14px; color: Theme.text; wrap: word-wrap;
                        }
                    }
                    Card {
                        title: root.tr-settings-units;
                        body: root.tr-settings-units-body;
                        HorizontalBox {
                            spacing: 8px;
                            ChoiceBtn { label: root.tr-settings-imperial; active: root.units == "IMPERIAL"; clicked => { root.set-units("IMPERIAL"); } }
                            ChoiceBtn { label: root.tr-settings-metric; active: root.units == "METRIC"; clicked => { root.set-units("METRIC"); } }
                        }
                        Text {
                            text: root.units == "METRIC"
                                ? "Metric: km · liters · L/100km · tread mm · oil in liters"
                                : "Imperial: miles · gallons · MPG · tread 1/32\" · oil in quarts";
                            font-size: 12px; color: Theme.text-muted; wrap: word-wrap;
                        }
                    }
                    Card {
                        title: root.tr-settings-language;
                        body: root.tr-settings-language-body;
                        // Full-width list (not tight 2-column rows) so every pack is visible
                        // and scrollable above the system nav bar.
                        VerticalBox {
                            spacing: 6px;
                            ChoiceBtn {
                                label: root.tr-settings-lang-system;
                                active: root.language == "SYSTEM";
                                horizontal-stretch: 1;
                                clicked => { root.set-language("SYSTEM"); }
                            }
                            ChoiceBtn {
                                label: "English";
                                active: root.language == "EN";
                                horizontal-stretch: 1;
                                clicked => { root.set-language("EN"); }
                            }
                            ChoiceBtn {
                                label: "Español";
                                active: root.language == "ES";
                                horizontal-stretch: 1;
                                clicked => { root.set-language("ES"); }
                            }
                            ChoiceBtn {
                                label: "Français";
                                active: root.language == "FR";
                                horizontal-stretch: 1;
                                clicked => { root.set-language("FR"); }
                            }
                            ChoiceBtn {
                                label: "Deutsch";
                                active: root.language == "DE";
                                horizontal-stretch: 1;
                                clicked => { root.set-language("DE"); }
                            }
                            ChoiceBtn {
                                label: "日本語";
                                active: root.language == "JA";
                                horizontal-stretch: 1;
                                clicked => { root.set-language("JA"); }
                            }
                            ChoiceBtn {
                                label: "한국어";
                                active: root.language == "KO";
                                horizontal-stretch: 1;
                                clicked => { root.set-language("KO"); }
                            }
                            ChoiceBtn {
                                label: "简体中文";
                                active: root.language == "ZH";
                                horizontal-stretch: 1;
                                clicked => { root.set-language("ZH"); }
                            }
                        }
                        Text {
                            text: root.language-active-label;
                            font-size: 12px; color: Theme.text-muted; wrap: word-wrap;
                        }
                    }
                    Card {
                        title: root.tr-settings-feature; body: root.tr-settings-feature-body;
                        HorizontalBox {
                            spacing: 6px;
                            ChoiceBtn { label: "DIY"; active: root.user-mode == "DIY"; clicked => { root.set-user-mode("DIY"); } }
                            ChoiceBtn { label: "SHOP"; active: root.user-mode == "SHOP"; clicked => { root.set-user-mode("SHOP"); } }
                            ChoiceBtn { label: "BOTH"; active: root.user-mode == "BOTH"; clicked => { root.set-user-mode("BOTH"); } }
                        }
                    }
                    Card {
                        title: root.tr-settings-data; body: root.tr-settings-data-body;
                        Button { text: root.tr-settings-export-csv; primary: true; clicked => { root.export-csv(); } }
                        Button { text: root.tr-settings-share-csv; clicked => { root.share-csv(); } }
                        Button { text: root.tr-settings-create-backup; clicked => { root.backup-json(); } }
                        Button { text: root.tr-settings-share-backup; clicked => { root.share-backup(); } }
                        LineEdit { placeholder-text: root.tr-settings-backup-path-ph; text <=> root.backup-path; }
                        Button { text: root.tr-settings-restore; clicked => { root.restore-json(); } }
                        if csv-preview != "": Text { text: csv-preview; font-size: 11px; color: Theme.mono; wrap: word-wrap; font-family: "monospace"; }
                    }
                    Card {
                        title: root.tr-settings-cloud;
                        body: root.tr-settings-cloud-body;
                        Button {
                            text: root.tr-settings-proton;
                            primary: true;
                            clicked => { root.share-backup-to("proton"); }
                        }
                        Button {
                            text: root.tr-settings-google-drive;
                            clicked => { root.share-backup-to("gdrive"); }
                        }
                        Button {
                            text: root.tr-settings-dropbox;
                            clicked => { root.share-backup-to("dropbox"); }
                        }
                        Button {
                            text: root.tr-settings-onedrive;
                            clicked => { root.share-backup-to("onedrive"); }
                        }
                        Text {
                            text: "If the app is missing, Android may open the store. Then run the button again and save the file in that app. ownCloud uses WebDAV below (same as Nextcloud).";
                            font-size: 12px; color: Theme.text-muted; wrap: word-wrap;
                        }
                    }
                    Card {
                        title: root.tr-settings-webdav;
                        body: root.tr-settings-webdav-hint;
                        LineEdit { placeholder-text: root.tr-settings-webdav-url-ph; text <=> root.cloud-url; }
                        LineEdit { placeholder-text: root.tr-settings-username; text <=> root.cloud-user; }
                        LineEdit { placeholder-text: root.tr-settings-password-ph; text <=> root.cloud-pass; }
                        Button { text: root.tr-settings-save-webdav; clicked => { root.save-cloud-settings(); } }
                        Button { text: root.tr-settings-upload-webdav; primary: true; clicked => { root.upload-cloud-backup(); } }
                    }
                    Card {
                        title: root.tr-settings-support; body: "GPL-3.0 · GrapheneOS friendly";
                        Button { text: root.tr-settings-donate; clicked => { root.open-donate(); } }
                        Button { text: root.tr-settings-feedback; clicked => { root.open-feedback(); } }
                    }
                    Card {
                        title: root.tr-settings-about;
                        body: root.tr-settings-about-body;
                    }
                    Card {
                        title: root.tr-rem-title;
                        body: root.tr-rem-reboot-hint;
                    }
                    if status-message != "": Text { text: status-message; color: Theme.ok; wrap: word-wrap; }
                }
            }

            // PARTS
            if page == 6: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 10px;
                    PageTitle { label: root.tr-page-parts; }
                    VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    Card {
                        title: "Current"; body: "";
                        Text { text: "Air: " + part-air; color: Theme.text; wrap: word-wrap; font-size: 13px; }
                        Text { text: "Cabin: " + part-cabin; color: Theme.text; wrap: word-wrap; font-size: 13px; }
                        Text { text: "Oil filter: " + part-oil-filter; color: Theme.text; wrap: word-wrap; font-size: 13px; }
                        Text { text: "Oil type: " + part-oil-type; color: Theme.text; wrap: word-wrap; font-size: 13px; }
                    }
                    Card {
                        title: "Save / update"; body: "Saving air/cabin/oil filter schedules a smart reminder (~12 mo / 15k for air & cabin; ~6 mo / 5k for oil filter).";
                        HorizontalBox {
                            spacing: 4px;
                            ChoiceBtn { label: "Air"; active: root.part-type == "ENGINE_AIR_FILTER"; clicked => { root.part-type = "ENGINE_AIR_FILTER"; } }
                            ChoiceBtn { label: "Cabin"; active: root.part-type == "CABIN_FILTER"; clicked => { root.part-type = "CABIN_FILTER"; } }
                        }
                        HorizontalBox {
                            spacing: 4px;
                            ChoiceBtn { label: "Oil filt"; active: root.part-type == "OIL_FILTER"; clicked => { root.part-type = "OIL_FILTER"; } }
                            ChoiceBtn { label: "Oil type"; active: root.part-type == "OIL_TYPE"; clicked => { root.part-type = "OIL_TYPE"; } }
                        }
                        LineEdit { placeholder-text: "Brand"; text <=> root.part-brand; }
                        LineEdit { placeholder-text: "Part number"; text <=> root.part-number; }
                        LineEdit { placeholder-text: "Oil viscosity (if oil type)"; text <=> root.part-oil; }
                        LineEdit { placeholder-text: "Installed " + root.label-distance; text <=> root.part-mileage; }
                        LineEdit { placeholder-text: "Notes"; text <=> root.part-notes; }
                        Button { text: "Save part"; primary: true; clicked => { root.save-part(); } }
                    }
                    Button { text: root.tr-common-back-more; clicked => { root.navigate(5); } }
                }
            }

            // BATTERY
            if page == 7: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 10px;
                    PageTitle { label: root.tr-page-battery; }
                    VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    Card { title: "Current"; body: sum-battery; }
                    Card { title: "Age check"; body: battery-warning; }
                    Card {
                        title: "Update"; body: "Date as YYYY-MM-DD";
                        LineEdit { placeholder-text: "Install date YYYY-MM-DD"; text <=> root.comp-date; }
                        LineEdit { placeholder-text: root.label-distance + " at install"; text <=> root.comp-mileage; }
                        LineEdit { placeholder-text: "Notes (brand, CCA…)"; text <=> root.comp-notes; }
                        Button {
                            text: "Save battery"; primary: true;
                            clicked => { root.comp-type = "BATTERY"; root.save-component(); }
                        }
                    }
                    Button { text: root.tr-common-back-more; clicked => { root.navigate(5); } }
                }
            }

            // WIPERS — driver (left) / passenger (right) / rear often different sizes
            if page == 8: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 10px;
                    PageTitle { label: root.tr-page-wipers; }
                    VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    Text {
                        text: "Many vehicles need different blade sizes. Labels use left/right as when sitting in the car (driver = left, passenger = right).";
                        font-size: 13px; color: Theme.text-muted; wrap: word-wrap;
                    }
                    Card {
                        title: "Driver side (left)";
                        body: sum-wiper-driver;
                    }
                    Card {
                        title: "Passenger side (right)";
                        body: sum-wiper-passenger;
                    }
                    Card {
                        title: "Rear";
                        body: sum-wiper-rear;
                    }
                    Card {
                        title: "Update blade";
                        body: "Pick which side, then enter size (e.g. 26 in) and install date.";
                        ChoiceBtn {
                            label: "Driver (left)";
                            active: root.comp-type == "WIPER_DRIVER";
                            clicked => { root.comp-type = "WIPER_DRIVER"; }
                        }
                        ChoiceBtn {
                            label: "Passenger (right)";
                            active: root.comp-type == "WIPER_PASSENGER";
                            clicked => { root.comp-type = "WIPER_PASSENGER"; }
                        }
                        ChoiceBtn {
                            label: "Rear";
                            active: root.comp-type == "WIPER_REAR";
                            clicked => { root.comp-type = "WIPER_REAR"; }
                        }
                        LineEdit { placeholder-text: "Blade size (e.g. 26 in / 650 mm)"; text <=> root.comp-notes; }
                        LineEdit { placeholder-text: "Install date YYYY-MM-DD"; text <=> root.comp-date; }
                        LineEdit { placeholder-text: root.label-distance + " at install"; text <=> root.comp-mileage; }
                        Button { text: "Save this blade"; primary: true; clicked => { root.save-component(); } }
                    }
                    Button { text: root.tr-common-back-more; clicked => { root.navigate(5); } }
                }
            }

            // BRAKES
            if page == 9: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 10px;
                    PageTitle { label: root.tr-page-brakes; }
                    VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    Text {
                        text: "Saving pads/fluid creates smart reminders (~30k mi / 2 years). Check Reminders for due items.";
                        font-size: 13px; color: Theme.text-muted; wrap: word-wrap;
                    }
                    Card { title: "Front pads"; body: sum-brake-f; }
                    Card { title: "Rear pads"; body: sum-brake-r; }
                    Card { title: "Brake fluid"; body: sum-brake-fluid; }
                    Card {
                        title: "Update"; body: "";
                        HorizontalBox {
                            ChoiceBtn { label: "Fr pads"; active: root.comp-type == "BRAKE_PADS_FRONT"; clicked => { root.comp-type = "BRAKE_PADS_FRONT"; } }
                            ChoiceBtn { label: "Rr pads"; active: root.comp-type == "BRAKE_PADS_REAR"; clicked => { root.comp-type = "BRAKE_PADS_REAR"; } }
                        }
                        ChoiceBtn { label: "Fluid"; active: root.comp-type == "BRAKE_FLUID"; clicked => { root.comp-type = "BRAKE_FLUID"; } }
                        LineEdit { placeholder-text: "Service date YYYY-MM-DD"; text <=> root.comp-date; }
                        LineEdit { placeholder-text: root.label-distance; text <=> root.comp-mileage; }
                        LineEdit { placeholder-text: "Notes"; text <=> root.comp-notes; }
                        Button { text: "Save brakes"; primary: true; clicked => { root.save-component(); } }
                    }
                    Button { text: root.tr-common-back-more; clicked => { root.navigate(5); } }
                }
            }

            // NOTES
            if page == 10: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 10px;
                    PageTitle { label: root.tr-page-notes; }
                    VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    Card {
                        title: "New note"; body: "";
                        LineEdit { placeholder-text: "Title"; text <=> root.note-title; }
                        LineEdit { placeholder-text: "Body"; text <=> root.note-body; }
                        Button { text: root.tr-notes-save; primary: true; clicked => { root.add-note(); } }
                    }
                    for n in notes: Card {
                        title: n.title; body: n.body;
                        Button { text: "Delete"; clicked => { root.delete-note(n.id); } }
                    }
                    Button { text: root.tr-common-back-more; clicked => { root.navigate(5); } }
                }
            }

            // REMINDERS
            if page == 11: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 10px;
                    PageTitle { label: root.tr-page-reminders; }
                    VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    Text {
                        text: "Oil level checks every 3 months are auto-created for new vehicles. Pick how full the oil is, then mark done.";
                        font-size: 13px; color: Theme.text-muted; wrap: word-wrap;
                    }

                    Card {
                        title: "Oil level (dipstick)";
                        body: last-oil-level-summary;
                        Text {
                            text: "When you check the oil, choose the level that matches the stick:";
                            font-size: 13px; color: Theme.text; wrap: word-wrap;
                        }
                        // Easy choices — labels follow imperial (qt) or metric (L)
                        ChoiceBtn {
                            label: root.oil-opt-0;
                            active: root.oil-level-choice == root.oil-opt-0 || root.oil-level-choice == "Full";
                            clicked => { root.set-oil-level-choice(root.oil-opt-0); }
                        }
                        ChoiceBtn {
                            label: root.oil-opt-1;
                            active: root.oil-level-choice == root.oil-opt-1;
                            clicked => { root.set-oil-level-choice(root.oil-opt-1); }
                        }
                        ChoiceBtn {
                            label: root.oil-opt-2;
                            active: root.oil-level-choice == root.oil-opt-2;
                            clicked => { root.set-oil-level-choice(root.oil-opt-2); }
                        }
                        ChoiceBtn {
                            label: root.oil-opt-3;
                            active: root.oil-level-choice == root.oil-opt-3;
                            clicked => { root.set-oil-level-choice(root.oil-opt-3); }
                        }
                        ChoiceBtn {
                            label: root.oil-opt-4;
                            active: root.oil-level-choice == root.oil-opt-4;
                            clicked => { root.set-oil-level-choice(root.oil-opt-4); }
                        }
                        ChoiceBtn {
                            label: root.oil-opt-5;
                            active: root.oil-level-choice == root.oil-opt-5 || root.oil-level-choice == "Overfilled";
                            clicked => { root.set-oil-level-choice(root.oil-opt-5); }
                        }
                        Text {
                            text: "Selected: " + root.oil-level-choice;
                            font-size: 13px; font-weight: 700; color: Theme.accent-on; wrap: word-wrap;
                        }
                    }

                    Card {
                        title: "Add reminder"; body: "Date YYYY-MM-DD and/or odometer. On Android, date dues schedule a wake alarm so the app can notify when due.";
                        LineEdit { placeholder-text: "Title"; text <=> root.rem-title; }
                        LineEdit { placeholder-text: root.tr-rem-due-date; text <=> root.rem-date; }
                        LineEdit { placeholder-text: "Due " + root.label-distance; text <=> root.rem-mileage; }
                        Button { text: root.tr-rem-save; primary: true; clicked => { root.add-reminder(); } }
                    }
                    for r in reminders: Card {
                        title: r.title; body: r.detail;
                        if r.is-oil-level: Text {
                            text: "Will log oil as: " + root.oil-level-choice;
                            font-size: 12px; color: Theme.text-muted; wrap: word-wrap;
                        }
                        Button {
                            text: r.is-oil-level ? "Log level & mark done" : "Mark done";
                            primary: r.is-oil-level;
                            clicked => { root.complete-reminder(r.id); }
                        }
                    }
                    Button { text: root.tr-common-back-more; clicked => { root.navigate(5); } }
                }
            }
        }


            // PHOTOS
            if page == 12: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 10px;
                    PageTitle { label: root.tr-page-photos; }
                    VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    Text {
                        text: "Log problems with a caption. On Android, Take photo opens the camera; then save the log entry.";
                        font-size: 13px; color: Theme.text-muted; wrap: word-wrap;
                    }
                    Card {
                        title: "New issue"; body: "";
                        LineEdit { placeholder-text: root.tr-photos-caption-ph; text <=> root.photo-caption; }
                        LineEdit { placeholder-text: "Notes / what you see"; text <=> root.photo-notes; }
                        Text {
                            text: photo-path == "" ? "No photo path yet" : ("Photo: " + photo-path);
                            font-size: 12px; color: Theme.text-soft; wrap: word-wrap;
                        }
                        Button { text: root.tr-photos-take; clicked => { root.capture-photo(); } }
                        Button { text: root.tr-photos-save; primary: true; clicked => { root.add-photo(); } }
                    }
                    for ph in photos: Card { title: ph.title; body: ph.detail; }
                    Button { text: root.tr-common-back-more; clicked => { root.navigate(5); } }
                }
            }

            // RECEIPT
            if page == 13: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 10px;
                    PageTitle { label: root.tr-page-receipts; }
                    VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    Text {
                        text: "On-device OCR (no Google): Capture photo → On-device OCR. Fallback: Send to OCR app / Share text back / Paste & fill. Metric km/L/€ OK.";
                        font-size: 13px; color: Theme.text-muted; wrap: word-wrap;
                    }
                    Card {
                        title: "Receipt fields"; body: "Saves into maintenance history for this vehicle.";
                        HorizontalBox {
                            spacing: 6px;
                            Button { text: root.tr-receipt-capture; primary: true; clicked => { root.capture-receipt-for-ocr(); } }
                            Button { text: root.tr-receipt-ondevice-ocr; primary: true; clicked => { root.ocr-receipt-on-device(); } }
                        }
                        HorizontalBox {
                            spacing: 6px;
                            Button { text: root.tr-receipt-send-ocr; clicked => { root.send-receipt-to-ocr(); } }
                            Button { text: root.tr-receipt-apply-shared; clicked => { root.apply-pending-ocr(); } }
                        }
                        HorizontalBox {
                            spacing: 6px;
                            Button { text: root.tr-tires-paste-fill; clicked => { root.paste-receipt-clipboard(); } }
                        }
                        Text {
                            text: rcp-photo-path == "" ? "No photo yet — capture or Share an image to FixItGarage." : ("Photo: " + rcp-photo-path);
                            font-size: 12px; color: Theme.text-soft; wrap: word-wrap;
                        }
                        HorizontalBox {
                            spacing: 6px;
                            Button { text: "Open OCR app"; clicked => { root.open-ocr-helper(); } }
                            Button { text: "Quick camera"; clicked => { root.capture-receipt-photo(); } }
                        }
                        LineEdit { placeholder-text: root.tr-receipt-paste-ph; text <=> root.rcp-paste; }
                        Button { text: root.tr-receipt-auto-fill; clicked => { root.parse-receipt-text(); } }
                        LineEdit { placeholder-text: root.tr-receipt-title-ph; text <=> root.rcp-title; }
                        LineEdit { placeholder-text: "Date YYYY-MM-DD"; text <=> root.rcp-date; }
                        LineEdit { placeholder-text: root.label-distance; text <=> root.rcp-mileage; }
                        LineEdit { placeholder-text: root.label-fuel + " (fuel)"; text <=> root.rcp-gallons; }
                        LineEdit { placeholder-text: "Parts cost"; text <=> root.rcp-parts; }
                        LineEdit { placeholder-text: "Labor cost"; text <=> root.rcp-labor; }
                        LineEdit { placeholder-text: "Fuel cost (optional)"; text <=> root.rcp-fuel; }
                        LineEdit { placeholder-text: "Shop name"; text <=> root.rcp-shop; }
                        Button { text: root.tr-receipt-save; primary: true; clicked => { root.save-receipt(); } }
                    }
                    Button { text: root.tr-common-back-more; clicked => { root.navigate(2); } }
                }
            }


            // FUEL / MPG HISTORY
            if page == 14: AppScrollView {
                width: 100%; height: 100%;
                VerticalBox {
                    padding: 16px; spacing: 10px;
                    PageTitle { label: root.tr-page-fuel; }
                    VehicleBar { prefix: root.tr-common-vehicle; switch-label: root.tr-common-switch; label: selected-vehicle-label; open-vehicles => { root.navigate(1); } }
                    Text { text: mpg-label; font-size: 15px; font-weight: 700; color: Theme.title; }
                    Text {
                        text: root.tr-fuel-each-fill;
                        font-size: 13px; color: Theme.text-muted; wrap: word-wrap;
                    }
                    for f in fuel-history: Card { title: f.title; body: f.detail; }
                    Button { text: root.tr-fuel-log-in-service; primary: true; clicked => { root.navigate(2); } }
                    Button { text: root.tr-common-back-home; clicked => { root.navigate(0); } }
                }
            }

        // Bottom nav — 4 large primary tabs (phone-friendly). Tires/Costs/Settings live under More + home shortcuts.
        // Lifted by safe-area-bottom so it clears the system nav (△ ○ □ / gesture bar).
        Rectangle {
            height: 72px + root.safe-area-bottom;
            background: Theme.nav-bg;
            border-width: 1px;
            border-color: Theme.surface-border;
            VerticalBox {
                padding: 0;
                spacing: 0;
                HorizontalBox {
                    height: 72px;
                    padding-left: 6px;
                    padding-right: 6px;
                    padding-top: 2px;
                    padding-bottom: 2px;
                    spacing: 4px;
                    NavBtn {
                        icon: "🏠";
                        label: root.nav-home;
                        active: root.page == 0;
                        clicked => { root.navigate(0); }
                    }
                    NavBtn {
                        icon: "🚗";
                        label: root.nav-cars;
                        active: root.page == 1;
                        clicked => { root.navigate(1); }
                    }
                    NavBtn {
                        icon: "🔧";
                        label: root.nav-service;
                        active: root.page == 2;
                        clicked => { root.navigate(2); }
                    }
                    NavBtn {
                        icon: "☰";
                        label: root.nav-more;
                        // More hub + nested tools + settings (gear) all highlight here
                        active: root.page >= 3;
                        clicked => { root.navigate(5); }
                    }
                }
                // Fills the system navigation bar zone (same color as app nav)
                Rectangle {
                    height: root.safe-area-bottom;
                    background: Theme.nav-bg;
                }
            }
        }
    }
}
