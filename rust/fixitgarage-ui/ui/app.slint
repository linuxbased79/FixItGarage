    in-out property <bool> show-tires: true;
    in-out property <bool> show-parts: true;
    in-out property <bool> show-diy-trackers: true;
    in-out property <bool> show-shop-emphasis: true;

    in-out property <string> last-service-title: "No services logged yet";
    in-out property <string> last-service-detail: "Add a service for the selected vehicle.";
