// FixItGarage — touch-friendly mobile UI (Slint)
// GPL-3.0. Multi-vehicle, trackers, reminders, notes, mode filtering.

import { Button, LineEdit, ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";

// Slint's default ScrollView has Flickable.interactive=false, so on touch devices
// you can only scroll with the thin scrollbar on the right edge. Enable pan/flick
// from anywhere (standard phone-app behavior).
component AppScrollView inherits ScrollView {
    mouse-drag-pan-enabled: true;
    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
}

// OpenDyslexic (SIL OFL) — optional accessibility font for dyslexia-friendly reading
import "./fonts/OpenDyslexic-Regular.otf";
import "./fonts/OpenDyslexic-Bold.otf";

export struct VehicleRow {
    id: int,
    name: string,
    subtitle: string,
    mileage: string,
}

export struct ServiceRow {
    id: int,
    title: string,
    subtitle: string,
    cost: string,
}

export struct CostLine {
    label: string,
    value: string,
}

export struct NoteRow {
    id: int,
    title: string,
    body: string,
}

export struct ReminderRow {
    id: int,
    title: string,
    detail: string,
    /// True when this is an oil dipstick check (show level picker).
    is-oil-level: bool,
}

export struct PhotoRow {
    id: int,
    title: string,
    detail: string,
}

export struct HistoryRow {
    id: int,
    title: string,
    detail: string,
}

export struct RecallRow {
    campaign: string,
    component: string,
    summary: string,
    detail: string,
}

export global Theme {
    in-out property <bool> dark: false;
    /// When true, UI uses OpenDyslexic (accessibility).
    in-out property <bool> dyslexia-font: false;
    /// Active UI font family (empty string = platform default).
    out property <string> ui-font: dyslexia-font ? "OpenDyslexic" : "";
    out property <color> bg: dark ? #0D1117 : #FAFAFA;
    out property <color> surface: dark ? #161B22 : #F5F5F5;
    out property <color> surface-border: dark ? #30363D : #E0E0E0;
    out property <color> nav-bg: dark ? #161B22 : #FFFFFF;
    out property <color> text: dark ? #E6EDF3 : #212121;
    out property <color> text-muted: dark ? #8B949E : #546E7A;
    out property <color> text-soft: dark ? #8B949E : #616161;
    out property <color> title: dark ? #81C784 : #1B5E20;
    out property <color> accent: #2E7D32;
    out property <color> accent-soft: dark ? #1B3D1F : #C8E6C9;
    out property <color> accent-on: dark ? #A5D6A7 : #1B5E20;
    out property <color> tire-bg: dark ? #1B3D1F : #E8F5E9;
    out property <color> tire-border: #2E7D32;
    out property <color> car-body: dark ? #21262D : #ECEFF1;
    out property <color> car-outline: dark ? #484F58 : #90A4AE;
    out property <color> mono: dark ? #C9D1D9 : #455A64;
    out property <color> ok: dark ? #81C784 : #2E7D32;
}

component TireCorner inherits Rectangle {
    in property <string> label;
    width: 56px; height: 48px; border-radius: 8px; border-width: 2px;
    border-color: Theme.tire-border; background: Theme.tire-bg;
    Text {
        text: root.label; color: Theme.accent-on; font-size: 16px; font-weight: 700;
        horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%;
    }
}

component NavBtn inherits TouchArea {
    in property <string> label;
    /// Optional icon glyph (e.g. 🏠). Prefer icon + short label for phone tabs.
    in property <string> icon: "";
    in property <bool> active;
    // Larger touch targets for phones (Material ~56–64dp)
    height: 68px; min-width: 64px; horizontal-stretch: 1;
    Rectangle {
        background: root.active ? Theme.accent-soft : transparent; border-radius: 12px;
        VerticalBox {
            padding-top: 6px; padding-bottom: 4px; spacing: 2px; alignment: center;
            if root.icon != "": Text {
                text: root.icon;
                color: root.active ? Theme.accent-on : Theme.text-muted;
                font-size: 24px; font-weight: 600;
                horizontal-alignment: center; width: 100%;
            }
            if root.label != "": Text {
                text: root.label;
                color: root.active ? Theme.accent-on : Theme.text-muted;
                // Was 9–11px — unreadable with 6–7 tabs. Keep readable with fewer tabs.
                font-size: 13px;
                font-weight: root.active ? 800 : 600;
                horizontal-alignment: center; width: 100%;
                overflow: elide;
            }
        }
    }
}

component ChoiceBtn inherits TouchArea {
    in property <string> label;
    in property <bool> active;
    min-height: 44px; min-width: 72px; horizontal-stretch: 1;
    Rectangle {
        border-radius: 10px; border-width: 2px;
        border-color: root.active ? Theme.accent : Theme.surface-border;
        background: root.active ? Theme.accent : Theme.surface;
        Text {
            text: root.label;
            color: root.active ? #FFFFFF : Theme.text;
            font-size: 14px; font-weight: 700;
            horizontal-alignment: center; vertical-alignment: center; width: 100%; height: 100%;
        }
    }
}

component Card inherits Rectangle {
    in-out property <string> title;
    in-out property <string> body;
    background: Theme.surface; border-radius: 12px; border-width: 1px; border-color: Theme.surface-border;
    VerticalBox {
        padding: 14px; spacing: 6px;
        Text { text: root.title; font-size: 16px; font-weight: 700; color: Theme.text; wrap: word-wrap; }
        if root.body != "": Text { text: root.body; font-size: 13px; color: Theme.text-soft; wrap: word-wrap; }
        @children
    }
}

component PageTitle inherits Text {
    in property <string> label;
    text: root.label; font-size: 24px; font-weight: 800; color: Theme.title;
}

component VehicleBar inherits HorizontalBox {
    in property <string> label;
    in property <string> prefix: "Vehicle";
    in property <string> switch-label: "Switch";
    callback open-vehicles();
    spacing: 8px;
    Text {
        text: root.prefix + ": " + root.label;
        font-size: 13px; color: Theme.text-muted; wrap: word-wrap;
        vertical-alignment: center; horizontal-stretch: 1;
    }
    Button { text: root.switch-label; clicked => { root.open-vehicles(); } }
}

export component MainWindow inherits Window {
    title: "FixItGarage";
    preferred-width: 390px; preferred-height: 780px; min-width: 320px; min-height: 560px;
    background: Theme.bg;
    // Empty = system/default UI font; "OpenDyslexic" when accessibility option is on
    default-font-family: Theme.ui-font;

    /// Extra space above the system navigation bar (3-button / gesture). Set from Rust on Android.
    in-out property <length> safe-area-bottom: 0px;
    /// Extra space below the status bar / cutout. Set from Rust on Android.
    in-out property <length> safe-area-top: 0px;

    in-out property <bool> wizard-done: false;
    in-out property <string> user-mode: "BOTH";
    /// OpenDyslexic accessibility font (saved on device)
